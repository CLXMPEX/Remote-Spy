add("Executor capability check:")
add("  setclipboard: " .. tostring(setclipboard ~= nil))
add("  getconnections: " .. tostring(getconnections ~= nil))
add("  VirtualInputManager: " .. tostring(pcall(function() return game:GetService("VirtualInputManager") end)))
add("  fireproximityprompt: " .. tostring(fireproximityprompt ~= nil))
local vim = nil
pcall(function() vim = game:GetService("VirtualInputManager") end)
if vim then
    add("  VIM.SendMouseButtonEvent: " .. tostring(pcall(function() return vim.SendMouseButtonEvent end)))
    add("  VIM.SendTouchEvent: " .. tostring(pcall(function() return vim.SendTouchEvent end)))
end
add("")
add("STEPS: open Start Invasion popup -> TAP the green button -> tap SCAN -> tap COPY -> paste to me.")
add("")
