-- ============================================================
--  INSTANT INVASION START  (remote-based, no button tapping)
--  This is the bypass we proved works: fire invasions.create
--  directly and the server starts the raid + teleports you in.
-- ============================================================

local function startInvasionInstant()
    if not R.createInvasion then
        warn("[AF] invasions.create remote missing — cannot start")
        return false
    end
    if isInRaidArea() then return true end

    State.startingInvasion = true
    State.startingInvasionAt = tick()

    print("[AF] Starting Dark Matter Invasion via remote...")
    for attempt = 1, 5 do
        if isInRaidArea() then
            State.startingInvasion = false
            print("[AF] In raid (instant start worked)")
            return true
        end
        -- the shape confirmed by the start test
        pcall(function()
            R.createInvasion:InvokeServer(INVASION.name, { friendsOnly = State.friendOnly })
        end)
        -- harmless variant in case the option name differs
        pcall(function()
            R.createInvasion:InvokeServer(INVASION.name, { friendsOnly = State.friendOnly, spawnNormal = false })
        end)
        print("[AF] Fired invasions.create (attempt " .. attempt .. ")")
        -- wait up to ~5s for the teleport
        for _ = 1, 10 do
            if isInRaidArea() then break end
            task.wait(0.5)
        end
    end

    State.startingInvasion = false
    if isInRaidArea() then
        return true
    end
    print("[AF] Instant start did not teleport us in")
    return false
end

local function equipBestWarriors()
