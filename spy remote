-- ============================================================
--  START INVASION SPY
--  Purpose: figure out EXACTLY why "Start Invasion 1x" won't click.
--
--  HOW TO USE:
--   1) Run this script.
--   2) Talk to Bald Hero -> Lead me -> get the "Start Invasion 1x"
--      popup on screen.
--   3) TAP the green "Start Invasion 1x" button with your finger.
--   4) Tap the yellow "SCAN" button in the spy bar (this dumps every
--      button currently on screen, even if your tap didn't register).
--   5) Tap the blue "COPY" button.
--   6) Paste the copied text back to me.
--
--  It captures: real taps (Activated + MouseButton1Click + InputBegan),
--  what's under your finger via GetGuiObjectsAtPosition, the FULL parent
--  chain of every matching button, AbsolutePosition/Size, Visible/Active
--  state, and whether getconnections returns anything.
-- ============================================================

local player = game.Players.LocalPlayer
local pgui = player:WaitForChild("PlayerGui", 10)
local UIS = game:GetService("UserInputService")

local result = "=== START INVASION SPY ===\n"
local count = 0
local running = true

local function add(s) result = result .. s .. "\n" end

-- ---- helpers --------------------------------------------------

local function safeText(o)
    local t = ""
    pcall(function() t = o.Text end)
    return t or ""
end

local function connInfo(o)
    local a, c, d, ib = 0, 0, 0, 0
    pcall(function() a = #getconnections(o.Activated) end)
    pcall(function() c = #getconnections(o.MouseButton1Click) end)
    pcall(function() d = #getconnections(o.MouseButton1Down) end)
    pcall(function() ib = #getconnections(o.InputBegan) end)
    return string.format("Act=%d Click=%d Down=%d IB=%d", a, c, d, ib)
end

local function parentChain(o, depth)
    local s = ""
    local p = o.Parent
    for i = 1, (depth or 8) do
        if not p or p == game then break end
        s = s .. "\n      ^ " .. p.Name .. " (" .. p.ClassName .. ")"
        p = p.Parent
    end
    return s
end

local function describe(o, tag)
    local okPos, pos = pcall(function() return o.AbsolutePosition end)
    local okSize, size = pcall(function() return o.AbsoluteSize end)
    local vis, act = "?", "?"
    pcall(function() vis = tostring(o.Visible) end)
    pcall(function() act = tostring(o.Active) end)
    local posStr = (okPos and pos) and (math.floor(pos.X) .. "," .. math.floor(pos.Y)) or "?"
    local sizeStr = (okSize and size) and (math.floor(size.X) .. "x" .. math.floor(size.Y)) or "?"

    add("")
    add((tag or "[OBJ]") .. " " .. o.ClassName .. "  text='" .. safeText(o) .. "'")
    add("    Path: " .. o:GetFullName())
    add("    Pos: " .. posStr .. "  Size: " .. sizeStr .. "  Visible=" .. vis .. "  Active=" .. act)
    add("    Conns: " .. connInfo(o))
    add("    ParentChain:" .. parentChain(o))
end

-- ---- 1) hook real taps on EVERY gui button -------------------
-- We hook Activated, MouseButton1Click, and InputBegan so we see the
-- tap no matter which event the button actually uses.

task.spawn(function()
    local hooked = {}
    local function hookGui(obj)
        if hooked[obj] then return end
        if not obj:IsA("GuiButton") then return end
        local sg = obj:FindFirstAncestorOfClass("ScreenGui")
        if sg and sg.Name == "StartInvasionSpy" then return end
        hooked[obj] = true

        pcall(function()
            obj.Activated:Connect(function()
                if not running then return end
                count = count + 1
                describe(obj, "[TAP-Activated #" .. count .. "]")
            end)
        end)
        pcall(function()
            obj.MouseButton1Click:Connect(function()
                if not running then return end
                count = count + 1
                describe(obj, "[TAP-Click #" .. count .. "]")
            end)
        end)
        pcall(function()
            obj.InputBegan:Connect(function(inp)
                if not running then return end
                if inp.UserInputType == Enum.UserInputType.Touch
                or inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    count = count + 1
                    describe(obj, "[TAP-InputBegan #" .. count .. "]")
                end
            end)
        end)
    end

    for _, d in ipairs(pgui:GetDescendants()) do
        pcall(function() hookGui(d) end)
    end
    pgui.DescendantAdded:Connect(function(d)
        task.wait(0.05)
        pcall(function() hookGui(d) end)
    end)
end)

-- ---- 2) track what is UNDER the finger on every tap ----------

UIS.InputBegan:Connect(function(input)
    if not running then return end
    if input.UserInputType ~= Enum.UserInputType.Touch
    and input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

    local pos = input.Position
    count = count + 1
    add("")
    add("[FINGER #" .. count .. "] tap at " .. math.floor(pos.X) .. "," .. math.floor(pos.Y))

    local guis = {}
    pcall(function() guis = pgui:GetGuiObjectsAtPosition(pos.X, pos.Y) end)
    if #guis == 0 then
        add("    (nothing returned by GetGuiObjectsAtPosition)")
    end
    for i, g in ipairs(guis) do
        if i > 8 then break end
        local sg = g:FindFirstAncestorOfClass("ScreenGui")
        if sg and sg.Name == "StartInvasionSpy" then continue end
        add("    [" .. i .. "] " .. g.ClassName .. " '" .. safeText(g) .. "'  " .. connInfo(g))
        add("        -> " .. g:GetFullName())
    end
end)

-- ---- 3) SCAN button: dump every on-screen button matching ----
-- Finds anything whose text mentions "invasion", "start", or "yes",
-- plus every visible GuiButton, with full details.

local function scanNow()
    add("")
    add("================ SCAN ================")

    -- 3a: labels/buttons whose text matches the keywords
    local keywords = {"start invasion", "invasion", "start", "yes"}
    add("-- Text matches --")
    for _, o in ipairs(pgui:GetDescendants()) do
        if o:IsA("TextLabel") or o:IsA("TextButton") or o:IsA("ImageButton") then
            local sg = o:FindFirstAncestorOfClass("ScreenGui")
            if sg and sg.Name == "StartInvasionSpy" then continue end
            local low = string.lower(safeText(o))
            if low ~= "" then
                for _, kw in ipairs(keywords) do
                    if string.find(low, kw, 1, true) then
                        describe(o, "[MATCH '" .. kw .. "']")
                        break
                    end
                end
            end
        end
    end

    -- 3b: every visible clickable button (so we see buttons with NO text,
    -- e.g. an ImageButton holding a separate text label)
    add("")
    add("-- All visible GuiButtons --")
    local n = 0
    for _, o in ipairs(pgui:GetDescendants()) do
        if o:IsA("GuiButton") and o.Visible then
            local sg = o:FindFirstAncestorOfClass("ScreenGui")
            if sg and sg.Name == "StartInvasionSpy" then continue end
            local okPos, pos = pcall(function() return o.AbsolutePosition end)
            local okSize, size = pcall(function() return o.AbsoluteSize end)
            -- skip tiny/offscreen
            if okSize and size and size.X > 20 and size.Y > 10 then
                n = n + 1
                if n <= 40 then
                    describe(o, "[BTN " .. n .. "]")
                end
            end
        end
    end
    add("Total visible buttons scanned: " .. n)
    add("================ END SCAN ================")
    add("")
end

-- ---- GUI bar -------------------------------------------------

local sg = Instance.new("ScreenGui", pgui)
sg.Name = "StartInvasionSpy"
sg.ResetOnSpawn = false
sg.DisplayOrder = 9999
sg.IgnoreGuiInset = true

local bar = Instance.new("Frame", sg)
bar.Size = UDim2.new(0, 320, 0, 40)
bar.Position = UDim2.new(0.5, -160, 0.02, 0)
bar.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
bar.BorderSizePixel = 0
Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 10)

local st = Instance.new("TextLabel", bar)
st.Size = UDim2.new(0, 110, 1, 0)
st.Position = UDim2.new(0, 8, 0, 0)
st.BackgroundTransparency = 1
st.TextColor3 = Color3.fromRGB(255, 210, 50)
st.Font = Enum.Font.GothamBold
st.TextSize = 12
st.TextXAlignment = Enum.TextXAlignment.Left
st.Text = "INV SPY: 0"

local function mkBtn(txt, color, posX, w)
    local b = Instance.new("TextButton", bar)
    b.Size = UDim2.new(0, w, 0, 28)
    b.Position = UDim2.new(0, posX, 0, 6)
    b.BackgroundColor3 = color
    b.Text = txt
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 12
    b.BorderSizePixel = 0
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    return b
end

local scanBtn = mkBtn("SCAN", Color3.fromRGB(230, 170, 40), 120, 60)
local copyBtn = mkBtn("COPY", Color3.fromRGB(70, 130, 210), 184, 60)
local stopBtn = mkBtn("STOP", Color3.fromRGB(200, 55, 55), 248, 60)

scanBtn.MouseButton1Click:Connect(function()
    scanNow()
    scanBtn.Text = "DONE"
    task.wait(0.8)
    scanBtn.Text = "SCAN"
end)

copyBtn.MouseButton1Click:Connect(function()
    local out = result .. "\nTotal events: " .. count .. "\n=== END ===\n"
    local ok = pcall(function() setclipboard(out) end)
    copyBtn.Text = ok and "COPIED" or "FAIL"
    task.wait(1)
    copyBtn.Text = "COPY"
end)

stopBtn.MouseButton1Click:Connect(function()
    running = false
    sg:Destroy()
end)

task.spawn(function()
    while running do
        task.wait(0.4)
        st.Text = "INV SPY: " .. count
    end
end)

