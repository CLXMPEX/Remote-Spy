local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local CONFIG = {
    RemoteFolderName = "InvasionRemotes",
    Raids = {
        {
            name = "Sunshine Raid",
            display = "Sunshine Lake",
            raidType = "bossRaid",
            startCFrame = CFrame.new(4982.6, 6007.8, -50.4),
            enabled = true,
        },
        {
            name = "Dark Matter Invasion",
            display = "Dark Matter",
            raidType = "invasion",
            startCFrame = CFrame.new(4911, 6020, 161),
            enabled = true,
        },
    },
}

local function getOrCreate(parent, className, name)
    local obj = parent:FindFirstChild(name)
    if obj and obj.ClassName == className then return obj end
    if obj then obj:Destroy() end

    obj = Instance.new(className)
    obj.Name = name
    obj.Parent = parent
    return obj
end

local function getRemote(name)
    local folder
    if RunService:IsServer() then
        folder = getOrCreate(ReplicatedStorage, "Folder", CONFIG.RemoteFolderName)
        return getOrCreate(folder, "RemoteEvent", name)
    end

    folder = ReplicatedStorage:WaitForChild(CONFIG.RemoteFolderName)
    return folder:WaitForChild(name)
end

local function findRaid(name)
    for _, raid in ipairs(CONFIG.Raids) do
        if raid.name == name or raid.display == name then
            return raid
        end
    end
    return CONFIG.Raids[2]
end

local function getRoot(player)
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function runServer()
    local requestStartPage = getRemote("RequestStartPage")
    local showStartPage = getRemote("ShowStartPage")
    local startRaid = getRemote("StartRaid")
    local raidStarted = getRemote("RaidStarted")
    local cooldown = {}

    local function allowed(player, raid)
        if not player or not raid or not raid.enabled then return false end
        local now = os.clock()
        if now - (cooldown[player.UserId] or 0) < 1 then return false end
        cooldown[player.UserId] = now
        return true
    end

    requestStartPage.OnServerEvent:Connect(function(player, raidName)
        local raid = findRaid(raidName)
        if not allowed(player, raid) then
            raidStarted:FireClient(player, { ok = false, message = "Not allowed yet" })
            return
        end

        showStartPage:FireClient(player, {
            raidName = raid.name,
            display = raid.display,
            raidType = raid.raidType,
        })
    end)

    startRaid.OnServerEvent:Connect(function(player, payload)
        payload = typeof(payload) == "table" and payload or {}
        local raid = findRaid(payload.raidName)

        if not allowed(player, raid) then
            raidStarted:FireClient(player, { ok = false, message = "Not allowed yet" })
            return
        end

        local root = getRoot(player)
        if not root then
            raidStarted:FireClient(player, { ok = false, message = "Character not ready" })
            return
        end

        -- Replace this with your real server-side invasion/lobby creation if needed.
        root.CFrame = raid.startCFrame

        raidStarted:FireClient(player, {
            ok = true,
            display = raid.display,
            friendsOnly = payload.friendsOnly == true,
        })
    end)

    print("[AF] Server loaded")
end

local function runClient()
    local player = Players.LocalPlayer
    local guiParent = player:WaitForChild("PlayerGui")

    local requestStartPage = getRemote("RequestStartPage")
    local showStartPage = getRemote("ShowStartPage")
    local startRaid = getRemote("StartRaid")
    local raidStarted = getRemote("RaidStarted")

    local state = {
        selectedRaid = CONFIG.Raids[2],
        friendOnly = false,
    }

    local old = guiParent:FindFirstChild("AutoFarmGUI")
    if old then old:Destroy() end

    local gui = Instance.new("ScreenGui")
    gui.Name = "AutoFarmGUI"
    gui.ResetOnSpawn = false
    gui.Parent = guiParent

    local main = Instance.new("Frame")
    main.Size = UDim2.new(0, 300, 0, 260)
    main.Position = UDim2.new(0.5, -150, 0.5, -130)
    main.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    main.Parent = gui
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -20, 0, 42)
    title.Position = UDim2.new(0, 10, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = "Auto Farm v10"
    title.TextColor3 = Color3.fromRGB(240, 240, 255)
    title.TextSize = 20
    title.Font = Enum.Font.GothamBold
    title.Parent = main

    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(1, -24, 0, 38)
    status.Position = UDim2.new(0, 12, 0, 56)
    status.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
    status.Text = "Ready"
    status.TextColor3 = Color3.fromRGB(180, 180, 200)
    status.TextSize = 13
    status.Font = Enum.Font.Gotham
    status.Parent = main
    Instance.new("UICorner", status).CornerRadius = UDim.new(0, 8)

    local function button(text, y, color, cb)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, -24, 0, 38)
        b.Position = UDim2.new(0, 12, 0, y)
        b.BackgroundColor3 = color
        b.Text = text
        b.TextColor3 = Color3.new(1, 1, 1)
        b.TextSize = 14
        b.Font = Enum.Font.GothamBold
        b.Parent = main
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
        b.MouseButton1Click:Connect(cb)
        return b
    end

    local raidButton
    raidButton = button("Raid: Dark Matter", 104, Color3.fromRGB(45, 45, 60), function()
        state.selectedRaid = state.selectedRaid == CONFIG.Raids[1] and CONFIG.Raids[2] or CONFIG.Raids[1]
        raidButton.Text = "Raid: " .. state.selectedRaid.display
    end)

    local friendButton
    friendButton = button("Friends Only: Off", 150, Color3.fromRGB(70, 55, 35), function()
        state.friendOnly = not state.friendOnly
        friendButton.Text = state.friendOnly and "Friends Only: On" or "Friends Only: Off"
    end)

    button("Open Start Page", 196, Color3.fromRGB(120, 90, 255), function()
        status.Text = "Opening start page..."
        requestStartPage:FireServer(state.selectedRaid.name)
    end)

    local startPage = Instance.new("Frame")
    startPage.Size = UDim2.new(0, 330, 0, 180)
    startPage.Position = UDim2.new(0.5, -165, 0.5, -90)
    startPage.BackgroundColor3 = Color3.fromRGB(24, 24, 34)
    startPage.Visible = false
    startPage.Parent = gui
    Instance.new("UICorner", startPage).CornerRadius = UDim.new(0, 12)

    local startTitle = Instance.new("TextLabel")
    startTitle.Size = UDim2.new(1, -24, 0, 50)
    startTitle.Position = UDim2.new(0, 12, 0, 12)
    startTitle.BackgroundTransparency = 1
    startTitle.Text = "Start Invasion"
    startTitle.TextColor3 = Color3.fromRGB(245, 245, 255)
    startTitle.TextSize = 22
    startTitle.Font = Enum.Font.GothamBold
    startTitle.Parent = startPage

    button("Start", 82, Color3.fromRGB(50, 205, 110), function()
        startPage.Visible = false
        startRaid:FireServer({
            raidName = state.selectedRaid.name,
            friendsOnly = state.friendOnly,
        })
    end).Parent = startPage

    showStartPage.OnClientEvent:Connect(function(payload)
        payload = typeof(payload) == "table" and payload or {}
        state.selectedRaid = findRaid(payload.raidName)
        startTitle.Text = "Start " .. state.selectedRaid.display
        startPage.Visible = true
    end)

    raidStarted.OnClientEvent:Connect(function(payload)
        payload = typeof(payload) == "table" and payload or {}
        status.Text = payload.ok and ("Started " .. tostring(payload.display)) or ("Failed: " .. tostring(payload.message))
    end)

    print("[AF] Client loaded")
end

if RunService:IsServer() then
    runServer()
elseif RunService:IsClient() then
    runClient()
end

return true
