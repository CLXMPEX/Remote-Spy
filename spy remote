-- INVASION BYPASS TEST
-- Run this in the lobby (NOT near Bald Hero) to see if direct remote works

local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local pgui = player:WaitForChild("PlayerGui", 10)
local result = "=== INVASION BYPASS TEST ===\n"

-- Find remote
local remoBase
pcall(function()
    remoBase = RS:WaitForChild("rbxts_include", 5)
        :WaitForChild("node_modules", 5):WaitForChild("@rbxts", 5)
        :WaitForChild("remo", 5):WaitForChild("src", 5):WaitForChild("container", 5)
end)

local createInvasion = remoBase and remoBase:FindFirstChild("invasions") and remoBase.invasions:FindFirstChild("create")
result = result .. "Remote found: " .. tostring(createInvasion ~= nil) .. "\n"
result = result .. "Remote class: " .. (createInvasion and createInvasion.ClassName or "nil") .. "\n"

-- Record Y position before
local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
local startY = hrp and hrp.Position.Y or 0
result = result .. "Start Y: " .. math.floor(startY) .. "\n\n"

-- Try InvokeServer
result = result .. "Trying InvokeServer...\n"
local invokeOk, invokeErr
if createInvasion then
    invokeOk, invokeErr = pcall(function()
        local ret = createInvasion:InvokeServer("Dark Matter Invasion", {friendsOnly = false})
        result = result .. "Return value: " .. tostring(ret) .. " (" .. typeof(ret) .. ")\n"
        if typeof(ret) == "table" then
            for k, v in pairs(ret) do
                result = result .. "  " .. tostring(k) .. " = " .. tostring(v) .. "\n"
            end
        end
    end)
    result = result .. "InvokeServer ok: " .. tostring(invokeOk) .. "\n"
    if not invokeOk then result = result .. "Error: " .. tostring(invokeErr) .. "\n" end
end

-- Wait and check if we teleported
task.wait(5)
hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
local endY = hrp and hrp.Position.Y or 0
result = result .. "\nAfter 5s Y: " .. math.floor(endY) .. "\n"
result = result .. "Teleported to raid: " .. tostring(endY > 5000) .. "\n"

-- Check if Start Invasion UI appeared
local foundStart = false
for _, obj in ipairs(pgui:GetDescendants()) do
    if obj:IsA("TextLabel") and obj.Visible then
        if string.find(string.lower(obj.Text), "start invasion", 1, true) then
            foundStart = true
            break
        end
    end
end
result = result .. "Start Invasion UI visible: " .. tostring(foundStart) .. "\n"

-- GUI
local sg = Instance.new("ScreenGui", pgui)
sg.Name = "BypassTest"; sg.ResetOnSpawn = false; sg.DisplayOrder = 999
local bar = Instance.new("Frame", sg)
bar.Size = UDim2.new(0.7, 0, 0, 36); bar.Position = UDim2.new(0.15, 0, 0.01, 0)
bar.BackgroundColor3 = Color3.fromRGB(20, 20, 25); bar.BorderSizePixel = 0
Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 10)

local status = Instance.new("TextLabel", bar)
status.Size = UDim2.new(0.5,0,1,0); status.Position = UDim2.new(0,8,0,0)
status.BackgroundTransparency = 1; status.TextColor3 = Color3.fromRGB(255,210,50)
status.TextSize = 10; status.Font = Enum.Font.GothamBold; status.TextXAlignment = Enum.TextXAlignment.Left
status.Text = endY > 5000 and "BYPASS WORKS!" or "Bypass failed"

local copyBtn = Instance.new("TextButton", bar)
copyBtn.Size = UDim2.new(0.22,0,0,26); copyBtn.Position = UDim2.new(0.52,0,0,5)
copyBtn.BackgroundColor3 = Color3.fromRGB(85,145,215); copyBtn.Text = "Copy"
copyBtn.TextColor3 = Color3.new(1,1,1); copyBtn.TextSize = 11; copyBtn.Font = Enum.Font.GothamBold
copyBtn.BorderSizePixel = 0
Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 6)

local stopBtn = Instance.new("TextButton", bar)
stopBtn.Size = UDim2.new(0.22,0,0,26); stopBtn.Position = UDim2.new(0.76,0,0,5)
stopBtn.BackgroundColor3 = Color3.fromRGB(200,55,55); stopBtn.Text = "Close"
stopBtn.TextColor3 = Color3.new(1,1,1); stopBtn.TextSize = 11; stopBtn.Font = Enum.Font.GothamBold
stopBtn.BorderSizePixel = 0
Instance.new("UICorner", stopBtn).CornerRadius = UDim.new(0, 6)

copyBtn.MouseButton1Click:Connect(function()
    setclipboard(result)
    copyBtn.Text = "Copied!"; task.wait(1); copyBtn.Text = "Copy"
end)
stopBtn.MouseButton1Click:Connect(function() sg:Destroy() end)
