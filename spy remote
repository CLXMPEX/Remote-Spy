end


-- ============================================================
--  WEBHOOK  (v10 — only on raid completion, with drops + run #)
-- ============================================================
local function getRequestFunction()
    return (syn and syn.request) or (http and http.request) or http_request or request
end

local function trimText(s)
    return (tostring(s):gsub("^%s+", ""):gsub("%s+$", ""))
end

-- scrape the victory screen for the drops the player received
local function getVictoryDrops()
    local afGui = pgui:FindFirstChild("AutoFarmGUI")
    local drops = {}
    local seen = {}
    local function consider(text)
        text = trimText(text)
        if text == "" or #text > 40 then return end
        local low = string.lower(text)
        if low == "rewards" or low == "reward" or low == "victory"
           or low == "continue" or low == "replay" or low == "drops"
           or string.find(low, "you got", 1, true) or string.find(low, "tap", 1, true) then
            return
        end
        if not seen[text] then seen[text] = true; table.insert(drops, text) end
    end

    -- find a panel mentioning reward/drops, scrape its labels
    for _, obj in ipairs(pgui:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Visible then
            if afGui and obj:IsDescendantOf(afGui) then continue end
            local low = string.lower(trimText(obj.Text))
            if low == "rewards" or low == "reward" or string.find(low, "drops", 1, true)
               or string.find(low, "you got", 1, true) or string.find(low, "you received", 1, true) then
                local panel = obj.Parent
                for _ = 1, 3 do
                    if panel and panel.Parent and panel.Parent ~= pgui then panel = panel.Parent end
                end
                if panel then
                    for _, d in ipairs(panel:GetDescendants()) do
                        if d:IsA("TextLabel") and d.Visible then consider(d.Text) end
                    end
                end
            end
        end
    end

    if #drops == 0 then return "No drops detected" end
    if #drops > 15 then
        local t = {}
        for i = 1, 15 do t[i] = drops[i] end
        table.insert(t, "...and more")
        drops = t
    end
    return table.concat(drops, "\n")
end

local function sendWebhook(title, description, color, extraFields)
    if not State.webhookEnabled then return end
    local url = trimText(State.webhookUrl)
    if url == "" then return end
    local req = getRequestFunction()
    if not req then warn("[AF] no HTTP request function for webhook"); return end

    local fields = {
        { name = "Raid",   value = INVASION.display, inline = true },
        { name = "Run #",  value = tostring(State.runCount or 0), inline = true },
        { name = "Player", value = player.Name, inline = true },
    }
    if extraFields then
        for _, f in ipairs(extraFields) do table.insert(fields, f) end
    end

    local payload = {
        username = "Auto Farm v11",
        embeds = {{
            title = title, description = description, color = color or 5763719,
            fields = fields, footer = { text = "Auto Farm v11" },
            timestamp = DateTime.now():ToIsoDate(),
        }},
    }
    task.spawn(function()
        local ok, err = pcall(function()
            req({ Url = url, Method = "POST",
                  Headers = { ["Content-Type"] = "application/json" },
                  Body = HttpService:JSONEncode(payload) })
        end)
        if not ok then warn("[AF] webhook failed: " .. tostring(err)) end
    end)
end


-- ============================================================
--  CLICK HELPERS  (for Replay button + modifier cards)
--  Uses the label-to-button walk that we proved reaches the
--  game's empty-text buttons via the 'inner' frame.
-- ============================================================
local function fireConns(btn)
    if not btn then return false end
    local fired = false
    for _, ev in ipairs({ "Activated", "MouseButton1Click", "MouseButton1Down" }) do
        pcall(function()
            for _, c in pairs(getconnections(btn[ev])) do c:Fire(); fired = true end
        end)
    end
    return fired
end

-- click the button under a label whose text contains searchText
local function clickByText(searchText)
    searchText = string.lower(searchText)
    local afGui = pgui:FindFirstChild("AutoFarmGUI")
    for _, obj in ipairs(pgui:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Visible then
            if afGui and obj:IsDescendantOf(afGui) then continue end
            if string.find(string.lower(obj.Text), searchText, 1, true) then
                local cur = obj.Parent
                for _ = 1, 8 do
                    if not cur or cur == pgui then break end
                    if cur.Name == "inner" then
                        local tb = cur:FindFirstChildOfClass("TextButton")
                            or cur:FindFirstChildOfClass("ImageButton")
                        if tb and fireConns(tb) then return true end
                    end
                    cur = cur.Parent
                end
            end
        end
    end
    return false
end

-- click a label whose text EXACTLY matches (used for Replay)
local function clickExact(exactText)
    local afGui = pgui:FindFirstChild("AutoFarmGUI")
    for _, obj in ipairs(pgui:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Visible and obj.Text == exactText then
            if afGui and obj:IsDescendantOf(afGui) then continue end
            local cur = obj.Parent
            for _ = 1, 8 do
                if not cur then break end
                if cur.Name == "inner" then
                    local tb = cur:FindFirstChildOfClass("TextButton")
                    if tb and fireConns(tb) then return true end
                    break
                end
                cur = cur.Parent
            end
        end
    end
    return false
end

-- ============================================================
--  PRESS THE IN-RAID START BUTTON  (Leave / Start / Kick bar)
--  After entering the raid the waves don't begin until the green
--  Start is pressed. We press the actual button (label->inner walk)
--  AND fire lobbies.start, retrying until enemies appear.
-- ============================================================
local function pressInRaidStart()
    print("[AF] Pressing in-raid Start...")
    for attempt = 1, 12 do
        if #getAliveEnemies() > 0 then
            print("[AF] Waves started (enemies present)")
            return true
        end
        -- press the green Start button several ways
        clickExact("Start")
        clickByText("start")
        -- also fire the lobby-start remote as a backup
        if R.lobbyStart then pcall(function() R.lobbyStart:FireServer() end) end
        task.wait(1)
    end
    return #getAliveEnemies() > 0
end

-- ============================================================
--  MODIFIER PICKER  (v10 — priority + tiers)
-- ============================================================
local function normalizeText(s)
    return string.lower(trimText(s))
end

-- tier value from card text: III=3, II=2, I=1, digits too
local function getModifierTier(text)
    local low = string.lower(text)
    if string.find(low, "iii", 1, true) then return 3 end
    if string.find(low, "ii", 1, true)  then return 2 end
    if string.find(low, " i", 1, true) or string.match(low, "%si$") then return 1 end
    local d = string.match(low, "(%d+)")
    if d then return tonumber(d) end
    return 0
end

local function modifierKeysMatch(cardKey, wantedKey)
    if string.find(cardKey, wantedKey, 1, true) or string.find(wantedKey, cardKey, 1, true) then return true end
    if string.find(cardKey, "overflowing", 1, true) and string.find(wantedKey, "overflowing", 1, true) then return true end
    if string.find(cardKey, "boss killer", 1, true) and string.find(wantedKey, "boss killer", 1, true) then return true end
    if string.find(cardKey, "blessing", 1, true) and string.find(wantedKey, "blessing", 1, true) then return true end
    return false
end

local function isKnownModifierText(low)
    if string.find(low, "overflowing", 1, true) or string.find(low, "boss killer", 1, true) then return true end
    if string.find(low, "blessing", 1, true) then return true end
    for _, opt in ipairs(ModifierOptions) do
        if opt ~= "Disabled" and string.find(low, normalizeText(opt), 1, true) then return true end
    end
    return false
end

-- collect visible modifier cards as {title, key, tier, obj}
local function collectModifierCards()
    local afGui = pgui:FindFirstChild("AutoFarmGUI")
    local cards = {}
    for _, obj in ipairs(pgui:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Visible then
            if afGui and obj:IsDescendantOf(afGui) then continue end
            local txt = trimText(obj.Text)
            local low = string.lower(txt)
            if txt ~= "" and isKnownModifierText(low) then
                table.insert(cards, {
                    title = txt, key = low,
                    tier = getModifierTier(txt), obj = obj,
                })
            end
        end
    end
    return cards
end

local function clickCard(card)
    local cur = card.obj.Parent
    for _ = 1, 10 do
        if not cur or cur == pgui then break end
        if cur.Name == "inner" then
            local tb = cur:FindFirstChildOfClass("TextButton")
                or cur:FindFirstChildOfClass("ImageButton")
            if tb and fireConns(tb) then return true end
        end
        cur = cur.Parent
    end
    return false
end

-- pick the highest-priority, highest-tier modifier; once per card set
local function autoVoteCard()
    if not State.autoPickModifiers then return false end
    local cards = collectModifierCards()
    if #cards == 0 then return false end

    -- signature so we only pick once per unique set of cards
    local sigParts = {}
    for _, c in ipairs(cards) do table.insert(sigParts, c.key .. tostring(c.tier)) end
    table.sort(sigParts)
    local signature = table.concat(sigParts, "|")
    if signature == State.lastModifierSignature and State.modifierPickedForSignature then
        return false
    end
    State.lastModifierSignature = signature

    -- score each card by its position in the priority list, then tier
    local best, bestPri, bestTier = nil, math.huge, -1
    for _, card in ipairs(cards) do
        for priIdx, wanted in ipairs(State.modifierPriorities) do
            if wanted ~= "Disabled" and modifierKeysMatch(card.key, normalizeText(wanted)) then
                if priIdx < bestPri or (priIdx == bestPri and card.tier > bestTier) then
                    best, bestPri, bestTier = card, priIdx, card.tier
                end
                break
            end
        end
    end

    if best then
        if clickCard(best) then
            State.modifierPickedForSignature = true
            print("[AF] Voted modifier: " .. best.title .. " (tier " .. tostring(best.tier) .. ")")
            return true
        end
    else
        -- nothing in priority list visible — pick the first card as fallback
        if clickCard(cards[1]) then
            State.modifierPickedForSignature = true
            print("[AF] Voted fallback modifier: " .. cards[1].title)
            return true
        end
    end
    return false
end


-- ============================================================
--  MAIN FARM LOOP  (v5 attack + no-walk fix + freeze window)
-- ============================================================
local function farmLoop()
    while State.running do
        -- hard pause while starting an invasion (nothing competes)
        if State.startingInvasion then
            repeat task.wait(0.1) until (not State.startingInvasion) or (not State.running)
        end

        task.wait(0.15)
        if not State.autoFarm then task.wait(0.5); continue end
        if not isInRaidArea() then task.wait(1); continue end

        -- freeze window after victory/replay so we don't chase ghosts
        if tick() < (State.freezeUntil or 0) then task.wait(0.2); continue end

        if State.autoEquipWeapon then equipWeapon() end

        local enemies = getAliveEnemies()
        if #enemies > 0 then
            local _, myHRP = getChar()
            if myHRP then
                table.sort(enemies, function(a, b)
                    return (myHRP.Position - a.hrp.Position).Magnitude
                         < (myHRP.Position - b.hrp.Position).Magnitude
                end)
            end
            attackTarget(enemies[1])
        else
            -- between waves / on boss: stand and swing (no fly-around)
            swingWeapon(); task.wait(0.1); swingWeapon()
        end
    end
end

-- ============================================================
--  RAID CYCLE LOOP  (instant start when in lobby)
-- ============================================================
local function raidCycleLoop()
    while State.running do
        task.wait(3)

        -- safety: never let the commit lock stick forever
        if State.startingInvasion and (tick() - (State.startingInvasionAt or 0)) > 60 then
            State.startingInvasion = false
        end

        if not State.autoFarm or not State.autoCreateRaid then continue end

        -- in raid? mark it and clear any stale flag handling
        if isInRaidArea() then
            State.inRaid = true
            continue
        end

        -- in lobby: clear stale inRaid, then start instantly
        if State.inRaid and not isInRaidArea()
           and tick() >= (State.freezeUntil or 0)
           and not State.startingInvasion then
            State.inRaid = false
        end

        if not isInRaidArea() and not State.inRaid and not State.startingInvasion then
            if State.autoEquipBestPet then equipBestWarriors(); task.wait(0.3) end
            if startInvasionInstant() then
                -- we're in the raid lobby now — press the green Start button
                -- (Leave / Start / Kick bar) so the waves actually begin.
                pressInRaidStart()
                if State.autoEquipWeapon then equipWeapon() end
                State.inRaid = true
                State.freezeUntil = tick() + 3
                print("[AF] Farming started!")
            end
        end
    end
end

-- ============================================================
--  VICTORY LOOP  (modifier voting + completion webhook + replay)
-- ============================================================
local function victoryLoop()
    while State.running do
        if State.startingInvasion then
            repeat task.wait(0.1) until (not State.startingInvasion) or (not State.running)
        end

        task.wait(1)
        if not State.autoFarm then continue end

        -- vote modifier cards while in the raid
        if State.inRaid then autoVoteCard() end

        -- detect Victory UI
        local afGui = pgui:FindFirstChild("AutoFarmGUI")
        local foundVictory = false
        for _, obj in ipairs(pgui:GetDescendants()) do
            if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and obj.Visible then
                if afGui and obj:IsDescendantOf(afGui) then continue end
                if string.find(string.lower(obj.Text), "victory", 1, true) then
                    foundVictory = true; break
                end
            end
        end

        if foundVictory then
            State.runCount = (State.runCount or 0) + 1
            print("[AF] Victory! Run #" .. State.runCount)
            task.wait(3)

            -- scrape drops BEFORE clicking replay (screen wipes after)
            local dropsText = State.webhookRewards and getVictoryDrops() or "Rewards hidden"
            sendWebhook(
                "Invasion Complete - Run #" .. State.runCount,
                "**" .. INVASION.display .. "** finished!",
                5763719,
                { { name = "Drops", value = dropsText, inline = false } }
            )

            -- freeze, then press Replay
            State.freezeUntil = tick() + 12
            print("[AF] Clicking Replay...")
            local replayed = false
            for _ = 1, 6 do
                if clickExact("Replay") then replayed = true; break end
                task.wait(1)
            end
            if not replayed then clickByText("replay") end

            State.freezeUntil = tick() + 12

            -- after replay, press in-raid Start so waves begin
            task.wait(3)
            for _ = 1, 10 do
                if #getAliveEnemies() > 0 then break end
                clickExact("Start")
                clickByText("start")
                if R.lobbyStart then pcall(function() R.lobbyStart:FireServer() end) end
                task.wait(1)
            end

            State.freezeUntil = tick() + 3
            State.lastModifierSignature = ""
            State.modifierPickedForSignature = false
            print("[AF] Replayed; continuing farm.")
        end
    end
end

-- ============================================================
--  UTILITY LOOP  (achievements + weapon upkeep)
-- ============================================================
local function utilityLoop()
    while State.running do
        if State.startingInvasion then
            repeat task.wait(0.1) until (not State.startingInvasion) or (not State.running)
        end
        task.wait(3)
