-- Update position display
task.spawn(function()
    while sg.Parent do
        task.wait(0.3)
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local p = char.HumanoidRootPart.Position
            posLabel.Text = string.format("Pos: %.0f, %.0f, %.0f", p.X, p.Y, p.Z)
        end
    end
end)

-- Save portal position
saveBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local p = char.HumanoidRootPart.Position
        local line = string.format("\n[PORTAL POS] %.1f, %.1f, %.1f", p.X, p.Y, p.Z)
        result = result .. line .. "\n"
        saveBtn.Text = "Saved!"
        saveBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        task.wait(1)
        saveBtn.Text = "Save Portal Pos"
        saveBtn.BackgroundColor3 = Color3.fromRGB(40, 180, 95)
    end
end)

-- Dump boss/enemy info
bossBtn.MouseButton1Click:Connect(function()
    local w = workspace:FindFirstChild("World")
    local ef = w and w:FindFirstChild("Enemies")
    if not ef then result = result .. "\nNo enemy folder found!\n"; return end
    
    result = result .. "\n=== ALL ENEMIES (detailed) ===\n"
    for _, e in ipairs(ef:GetChildren()) do
        if e:IsA("Model") then
            result = result .. "\nEnemy: " .. e.Name .. "\n"
            
            -- All attributes
            local attrs = e:GetAttributes()
            if next(attrs) then
                for k, v in pairs(attrs) do
                    result = result .. "  [attr] " .. k .. " = " .. tostring(v) .. " (" .. typeof(v) .. ")\n"
                end
            else
                result = result .. "  [attr] NONE\n"
            end
            
            -- Humanoid
            local hum = e:FindFirstChildOfClass("Humanoid")
            if hum then
                result = result .. "  [hum] Name='" .. hum.Name .. "' Display='" .. tostring(hum.DisplayName) .. "' HP=" .. hum.Health .. "/" .. hum.MaxHealth .. "\n"
            else
                result = result .. "  [hum] NO HUMANOID\n"
            end
            
            -- HumanoidRootPart
            local hrp = e:FindFirstChild("HumanoidRootPart")
            if hrp then
                result = result .. "  [pos] " .. string.format("%.0f, %.0f, %.0f", hrp.Position.X, hrp.Position.Y, hrp.Position.Z) .. "\n"
            else
                result = result .. "  [pos] NO HRP\n"
            end
            
            -- All children (full list)
            result = result .. "  [children] "
            for _, c in ipairs(e:GetChildren()) do
                result = result .. c.Name .. "(" .. c.ClassName .. ") "
            end
            result = result .. "\n"
            
            -- Billboards
            for _, desc in ipairs(e:GetDescendants()) do
                if desc:IsA("TextLabel") and desc.Text ~= "" then
                    result = result .. "  [text] '" .. desc.Text .. "' in " .. desc.Parent.ClassName .. "\n"
                end
            end
        end
    end
    
    bossBtn.Text = "Dumped!"
    task.wait(1)
    bossBtn.Text = "Dump Boss Info"
end)

-- Copy
copyBtn.MouseButton1Click:Connect(function()
    setclipboard(result)
    copyBtn.Text = "Copied!"
    task.wait(1)
    copyBtn.Text = "Copy All"
end)

-- Close
closeBtn.MouseButton1Click:Connect(function() sg:Destroy() end)
